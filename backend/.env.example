# =====================================================
# Meloniq Backend — environment config template
# Copy this file to `.env` in the `backend` directory:
#   cp .env.example .env
# =====================================================

# Your Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Vision model used for analysis.
# Select the model that best matches your performance & accuracy needs:
#
# 1. gemini-3.5-flash (DEFAULT - Recommended)
#    - PROS: Excellent balance of vision accuracy, detailed skin observations, fast latency (1-2s), generous free-tier rate limits.
#    - CONS: Slightly higher latency than flash-lite.
#
# 2. gemini-3.5-flash-lite
#    - PROS: Ultra-fast sub-second latency (<1s response times), lowest token cost, ideal for high-traffic live event booths.
#    - CONS: Slightly less detailed skin observation notes on subtle redness/pore nuances.
#
# 3. gemini-3.5-pro
#    - PROS: Highest precision vision reasoning, handles uneven lighting & reflections best, rich dermatological observation notes.
#    - CONS: Higher latency (3-5s per scan), lower free-tier rate limits (15 requests/min).
#
SKIN_ANALYSIS_MODEL=gemini-3.5-flash

# Port the backend API & WebSocket server listens on
PORT=3000
