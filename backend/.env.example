# =====================================================
# Meloniq Backend — environment config template
# Copy this file to `.env` in the `backend` directory:
#   cp .env.example .env
# =====================================================

# Your Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Vision model used for analysis.
# Select the model that best matches your performance & accuracy needs:
#
# 1. gemini-3.5-flash (DEFAULT - Recommended)
#    - PROS: Good balance of vision accuracy, detailed skin observations, fast latency (1-2s).
#    - CONS: Free-tier RPM/RPD budgets are modest; 429s are possible under sustained booth load.
#
# 2. gemini-3.5-flash-lite
#    - PROS: Ultra-fast sub-second latency (<1s response times), lowest token cost,
#            ideal for high-traffic live event booths.
#    - CONS: Slightly less detailed skin observation notes on subtle redness/pore nuances.
#
# 3. gemini-3.5-pro  ⚠️  PAID-ONLY as of April 2026 — no free tier.
#    - PROS: Highest precision vision reasoning, handles uneven lighting & reflections best,
#            rich dermatological observation notes.
#    - CONS: Requires a billing-enabled project. Higher latency (3-5s per scan).
#
SKIN_ANALYSIS_MODEL=gemini-3.5-flash

#Optional secondary fallback model if the primary model hits RPM/RPD rate limits.
#Must differ from SKIN_ANALYSIS_MODEL to have any effect.
# Example: FALLBACK_MODEL=gemini-3.5-flash-lite
FALLBACK_MODEL=gemini-3.1-flash-lite
# Concurrency control & queue timeout for protecting free-tier Gemini RPM budget.
MAX_CONCURRENT_GEMINI_CALLS=1
GEMINI_QUEUE_TIMEOUT_MS=30000

# Per-call timeout (milliseconds) for individual Gemini API calls.
# A call that hangs longer than this is aborted and treated as a transient 503,
# eligible for normal retry/backoff. Prevents hung calls from blocking the queue.
# Default: 20000 (20 seconds). Set to 0 to disable.
GEMINI_REQUEST_TIMEOUT_MS=20000

# Maximum total raw Gemini HTTP attempts (primary retries + fallback retries, each
# individual HTTP call counted separately) allowed per single /api/analyze request.
# Default: 8. With json_schema enforcement, invalid-report retries are rarely needed,
# so 8 comfortably covers 3 primary + 3 fallback + 2 spare slots.
GEMINI_MAX_CALLS_PER_REQUEST=8

# Optional daily-quota detection hint. If set, and a 429 arrives after this many
# attempted calls to a model today (in-process counter, resets at midnight Pacific time),
# the 429 will be classified as RPD (daily quota exhaustion) even if Gemini's error body
# is empty. This is useful because Gemini's OpenAI-compat endpoint often returns 429s
# with no body, making it impossible to distinguish RPM from RPD via error text alone.
# Set this to roughly your model's daily free-tier request limit (e.g. 1500 for Flash).
# Leave unset (default) to disable the heuristic and rely only on error-text matching.
GEMINI_DAILY_LIMIT_HINT=1500

# Circuit breaker — prevents wasting retry delay against a model that is already
# quota-hot. After N consecutive quota failures (RPM/RPD/TPM) within the cooldown
# window, the primary model is skipped and the request goes straight to the fallback.
# The breaker resets automatically on any successful call, or after the cooldown expires.
CIRCUIT_BREAKER_THRESHOLD=2       # consecutive quota failures before tripping
CIRCUIT_BREAKER_COOLDOWN_MS=60000 # how long the breaker stays open (ms)

# Retry settings for individual Gemini model calls.
GEMINI_MAX_RETRIES=3
GEMINI_INITIAL_RETRY_DELAY_MS=1500

# Port the backend API & WebSocket server listens on
PORT=3000
AI_SERVICE_PORT=8000
