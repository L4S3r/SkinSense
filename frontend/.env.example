# =====================================================
# Meloniq Frontend — environment config template
# Copy this file to `.env` in the `frontend` directory.
#   cp .env.example .env
# =====================================================

# Direct backend API & WebSocket base URL.
# - For local development (backend on port 3000): http://localhost:3000
# - For mini-server / LAN deployment: http://<mini-server-ip>:3000 (e.g. http://192.168.1.100:3000)
VITE_API_BASE_URL=http://localhost:3000
