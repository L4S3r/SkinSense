# =====================================================
# Lumen — environment config template
# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
# =====================================================

# Your Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Vision model used for analysis. gemini-2.5-flash is fast and has a
# generous free tier. Alternatives: gemini-2.5-flash-lite, gemini-2.5-pro
SKIN_ANALYSIS_MODEL=gemini-2.5-flash

# Port the server listens on
PORT=3000
